<?xml version="1.0"?>
<extension type="plugin" method="upgrade" group="jshoppingadmin">
    <name>PLG_WTINDEXNOWJSHOPPING</name>
    <author>Sergey Tolkachyov</author>
    <authorEmail>info@web-tolk.ru</authorEmail>
    <authorUrl>https://web-tolk.ru</authorUrl>
    <creationDate>11.12.2025</creationDate>
    <copyright>Copyright (c) 2025 Sergey Tolkachyov. All rights reserved.</copyright>
    <license>GNU General Public License v3.0</license>
    <version>1.0.0</version>
    <description>PLG_WTINDEXNOWJSHOPPING_DESC</description>
    <namespace path="src">Joomla\Plugin\Jshoppingadmin\Wtindexnowjshopping</namespace>
    <scriptfile>script.php</scriptfile>
	<media destination="plg_jshoppingadmin_wtindexnowjshopping" folder="media">
		<folder>js</folder>
	</media>
    <files>
        <folder plugin="wtindexnowjshopping">src</folder>
        <folder>services</folder>
        <folder>language</folder>
    </files>
    <languages folder="language" client="administrator">
        <language tag="en-GB">en-GB/plg_jshoppingadmin_wtindexnowjshopping.ini</language>
		<language tag="en-GB">en-GB/plg_jshoppingadmin_wtindexnowjshopping.sys.ini</language>
        <language tag="ru-RU">ru-RU/plg_jshoppingadmin_wtindexnowjshopping.ini</language>
        <language tag="ru-RU">ru-RU/plg_jshoppingadmin_wtindexnowjshopping.sys.ini</language>
    </languages>
	<media folder="media" destination="plg_jshoppingadmin_wtindexnowjshopping">
		<folder>js</folder>
	</media>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field addfieldprefix="Joomla\Plugin\Jshoppingadmin\Wtindexnowjshopping\Fields" type="plugininfo" name="plugininfo"/>
				<field	type="radio"
						  name="show_button"
						  label="PLG_WTINDEXNOWJSHOPPING_SHOW_BUTTON"
						  description="PLG_WTINDEXNOWJSHOPPING_SHOW_BUTTON_DESC"
						  layout="joomla.form.field.radio.switcher"
						  default="1"
						  filter="boolean"
				>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field	type="radio"
						  name="send_unpublished"
						  label="PLG_WTINDEXNOWJSHOPPING_SEND_UNPUBLISHED"
						  description="PLG_WTINDEXNOWJSHOPPING_SEND_UNPUBLISHED_DESC"
						  layout="joomla.form.field.radio.switcher"
						  default="0"
						  filter="integer"
						  >
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
            </fieldset>
        </fields>
    </config>
</extension>