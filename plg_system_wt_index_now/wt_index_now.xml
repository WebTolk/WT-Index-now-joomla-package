<?xml version="1.0"?>
<extension type="plugin" method="upgrade" group="system">
    <name>System - WT Index now</name>
    <author>Sergey Tolkachyov and Sergey Sergevnin</author>
    <authorEmail>info@web-tolk.ru</authorEmail>
    <authorUrl>https://web-tolk.ru</authorUrl>
    <creationDate>17.11.2025</creationDate>
    <copyright>Copyright (c) 2018 - 2025 Sergey Tolkachyov. All rights reserved.</copyright>
    <license>GNU General Public License v3.0</license>
    <version>1.0.0</version>
    <description>PLG_WT_INDEX_NOW_DESC</description>
    <namespace path="src">Joomla\Plugin\System\Wt_index_now</namespace>
    <scriptfile>script.php</scriptfile>
    <files>
        <folder plugin="wt_index_now">src</folder>
        <folder>language</folder>
		<folder>services</folder>
		<folder>sql</folder>
    </files>
    <languages folder="language" client="administrator">
        <language tag="en-GB">en-GB/plg_system_wt_index_now.ini</language>
        <language tag="ru-RU">ru-RU/plg_system_wt_index_now.ini</language>
        <language tag="en-GB">en-GB/plg_system_wt_index_now.sys.ini</language>
        <language tag="ru-RU">ru-RU/plg_system_wt_index_now.sys.ini</language>
    </languages>
    <media folder="media" destination="plg_system_wt_index_now">
        <folder>js</folder>
        <filename>joomla.asset.json</filename>
    </media>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field addfieldprefix="Joomla\Plugin\System\Wt_index_now\Fields"
                       type="token"
                       name="webhook_token"
                       label="PLG_WT_INDEX_NOW_KEY"/>
                <field addfieldprefix="Joomla\Plugin\System\Wt_index_now\Fields" type="plugininfo" name="plugininfo"/>
                <field addfieldprefix="Joomla\Plugin\System\Wt_index_now\Fields" type="botinfo" name="botinfo"/>
                <field type="text" name="telegram_api_token" label="PLG_WT_INDEX_NOW_TELEGRAM_API_TOKEN"/>
                <field addfieldprefix="Joomla\Plugin\System\Wt_index_now\Fields"  type="chatidinfo"
                       name="telegram_chat_id" label="PLG_WT_INDEX_NOW_TELEGRAM_CHAT_ID"/>
                <field type="text" name="message_thread_id" label="PLG_WT_INDEX_NOW_MESSAGE_THREAD_ID"/>
                <field type="note" name="code_example" label="PLG_WT_INDEX_NOW_CODE_EXAMPLE_LABEL" description="PLG_wt_index_now_CODE_EXAMPLE"/>
                <field type="note" name="code_example_desc" label="PLG_WT_INDEX_NOWCODE_DESC_LABEL" description="PLG_wt_index_now_CODE_DESC"/>
            </fieldset>
        </fields>
    </config>
    <updateservers>
        <server type="extension" priority="1" name="WT Index now updates">https://web-tolk.ru/component/wt_index_now
            /jupdate?element=wt_index_now</server>
    </updateservers>
    <changelogurl>https://web-tolk.ru/jchangelog?element=wt_index_now</changelogurl>
</extension>