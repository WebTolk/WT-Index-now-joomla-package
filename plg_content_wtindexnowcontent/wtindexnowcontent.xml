<?xml version="1.0"?>
<extension type="plugin" method="upgrade" group="content">
    <name>PLG_WTINDEXNOWCONTENT</name>
    <author>Sergey Tolkachyov</author>
    <authorEmail>info@web-tolk.ru</authorEmail>
    <authorUrl>https://web-tolk.ru</authorUrl>
    <creationDate>06.12.2025</creationDate>
    <copyright>Copyright (c) 2025 Sergey Tolkachyov. All rights reserved.</copyright>
    <license>GNU General Public License v3.0</license>
    <version>1.0.0</version>
    <description>PLG_WTINDEXNOWCONTENT_DESC</description>
    <namespace path="src">Joomla\Plugin\Content\Wtindexnowcontent</namespace>
    <scriptfile>script.php</scriptfile>
	<media destination="plg_content_wtindexnowcontent" folder="media">
		<folder>js</folder>
	</media>
    <files>
        <folder plugin="wtindexnowcontent">src</folder>
        <folder>services</folder>
        <folder>language</folder>
    </files>
    <languages folder="language" client="administrator">
        <language tag="en-GB">en-GB/plg_content_wtindexnowcontent.ini</language>
		<language tag="en-GB">en-GB/plg_content_wtindexnowcontent.sys.ini</language>
        <language tag="ru-RU">ru-RU/plg_content_wtindexnowcontent.ini</language>
        <language tag="ru-RU">ru-RU/plg_content_wtindexnowcontent.sys.ini</language>
    </languages>
	<media folder="media" destination="plg_content_wtindexnowcontent">
		<folder>js</folder>
	</media>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field addfieldprefix="Joomla\Plugin\Content\Wtindexnowcontent\Fields" type="plugininfo" name="plugininfo"/>
				<field	type="radio"
						  name="send_unpublished"
						  label="PLG_WTINDEXNOWCONTENT_SEND_UNPUBLISHED"
						  description="PLG_WTINDEXNOWCONTENT_SEND_UNPUBLISHED_DESC"
						  layout="joomla.form.field.radio.switcher"
						  default="0"
						  filter="integer"
						  >
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
            </fieldset>
        </fields>
    </config>
    <updateservers>
        <server type="extension" priority="1" name="WT Index now updates">https://web-tolk.ru/component/swjprojects/jupdate?element=wtindexnowcontent</server>
    </updateservers>
    <changelogurl>https://web-tolk.ru/jchangelog?element=wtindexnowcontent</changelogurl>
</extension>